{
  "manifest_version": 3,
  "name": "Style Catcher",
  "description": "이미지를 올리면 디자인 스타일을 분석해요",
  "version": "1.0",
  "permissions": ["activeTab", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "css": ["overlay.css"]
  }],
  "commands": {
    "lens-search": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "캡처해서 Google Lens 검색"
    }
  },
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}
